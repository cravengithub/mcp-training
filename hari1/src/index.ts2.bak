import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import fs from 'fs/promises';
import path from 'path';
import process from 'process';
import { fileURLToPath } from 'url';

// Untuk mendapatkan __dirname di ES modules
const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Inisialisasi server
const server = new McpServer({
    name: "resource-server",
    version: "1.0.0"
});

// ============ RESOURCE 1: Users Data ============
server.resource(
    "users", // Nama resource
    "file:///data/users.json", // URI resource
    async (uri) => {
        try {
            // Tentukan path absolut ke file
            const filePath = path.join(__dirname, "../data/users.json");
            // Baca file
            const content = await fs.readFile(filePath, 'utf-8');
            // Validasi JSON (opsional)
            JSON.parse(content); // Akan throw error jika JSON tidak valid
            // Kembalikan konten
            return {
                contents: [{
                    uri: uri.href,
                    mimeType: "application/json",
                    text: content
                }]
            };
        } catch (error: unknown) {
            const err = error as { code?: string };
            if (err?.code === 'ENOENT') {
                throw new Error(`Resource not found: ${uri}`);
            }
            if (error instanceof SyntaxError) {
                throw new Error(`Invalid JSON in resource: ${error.message}`);
            }
            const message = error instanceof Error ? error.message : String(error);
            throw new Error(`Failed to read resource: ${message}`);
        }
    }
);
// ============ RESOURCE 2: Config Data ============
server.resource(
    "config",
    "file:///data/config.json",
    async (uri) => {
        try {
            const filePath = path.join(__dirname, "../data/config.json");
            const content = await fs.readFile(filePath, 'utf-8');
            return {
                contents: [{
                    uri: uri.href,
                    mimeType: "application/json",
                    text: content
                }]
            };
        } catch (error: unknown) {
            const err = error as { code?: string };
            if (err?.code === 'ENOENT') {
                throw new Error(`Resource not found: ${uri}`);
            }
            const message = error instanceof Error ? error.message : String(error);
            throw new Error(`Failed to read resource: ${message}`);
        }
    }
);
// ============ TOOL PING (Tetap dipertahankan) ============
server.tool("ping", "Send a ping to check if the server is alive", async () => ({
    content: [{ type: "text", text: "pong" }]
}));
// Main function
async function main() {
    const transport = new StdioServerTransport();
    await server.connect(transport);
    console.error("✅ MCP Server with Resources is running");
    console.error("📁 Available resources: users.json, config.json");
    console.error("🔧 Available tools: ping");
}
main().catch((error) => {
    console.error("❌ Fatal error:", error);
    process.exit(1);
});